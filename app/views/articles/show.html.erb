<p class="flash-notice" style="color: green"><%= notice %></p>

<div class="article-container">
  <div class="article-header">
    <h1 class="article-title"><%= @article.title %></h1>
    <div class="article-meta">
      <%= t("articles.show.posted_at", date: @article.created_at.strftime("%Y-%m-%d %H:%M")) %>
    </div>
  </div>

  <div class="article-body">
    <%= simple_format @article.content %>
  </div>

  <% if @article.files_count > 0 %>
    <div class="attachments-section">
      <h3 class="section-title"><%= t("articles.show.attachments", count: @article.files_count) %></h3>
      <div class="attachments-layout">
        
        <% if (images = @article.attached_images).any? %>
          <div class="gallery-block">
            <h4><%= t("articles.show.gallery") %></h4>
            <div class="gallery-grid">
              <% images.each do |image| %>
                <div class="gallery-item">
                  <%= link_to url_for(image), target: "_blank", class: "gallery-link" do %>
                    <%= image_tag image, class: "gallery-img" %>
                  <% end %>
                  <div class="gallery-meta">
                    <span class="file-name" title="<%= image.filename %>"><%= image.filename.to_s.truncate(20) %></span>
                    <%= link_to rails_blob_path(image, disposition: "attachment"), class: "btn-download-sm", title: t("articles.show.download") do %>
                      <%= embedded_svg("download") %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <% if (docs = @article.attached_documents).any? %>
          <div class="docs-block">
            <h4><%= t("articles.show.documents") %></h4>
            <div class="docs-list">
              <% docs.each do |doc| %>
                <div class="doc-item">
                  <div class="doc-icon-wrapper">
                    <% if doc.content_type == "application/pdf" %>
                      <div class="doc-icon pdf">
                        <%= embedded_svg("file") %>
                        <span>PDF</span>
                      </div>
                    <% else %>
                      <div class="doc-icon generic">
                        <%= embedded_svg("file") %>
                        <span><%= doc.filename.extension.to_s.upcase %></span>
                      </div>
                    <% end %>
                  </div>
                  <div class="doc-info">
                    <span class="doc-name" title="<%= doc.filename %>"><%= doc.filename.to_s.truncate(30) %></span>
                    <span class="doc-size"><%= number_to_human_size(doc.byte_size) %></span>
                  </div>
                  <div class="doc-actions">
                    <%= link_to t("articles.show.open"), url_for(doc), target: "_blank", class: "btn btn-sm btn-open" %>
                    <%= link_to t("articles.show.download_short"), rails_blob_path(doc, disposition: "attachment"), class: "btn btn-sm btn-dl" %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

      </div>
    </div>
  <% end %>

  <div class="article-actions">
    <%= link_to edit_article_path(@article), class: "btn btn-edit" do %>
      <%= embedded_svg("pencil") %>
      <%= t("articles.show.edit") %>
    <% end %>
    <%= link_to articles_path, class: "btn btn-back" do %>
      <%= embedded_svg("arrow-left") %>
      <%= t("articles.show.back") %>
    <% end %>
    <%= button_to @article, method: :delete, class: "btn btn-danger", form: { data: { turbo_confirm: t("articles.show.confirm_delete") }, class: "inline-form" } do %>
      <%= embedded_svg("trash") %>
      <%= t("articles.show.delete") %>
    <% end %>
  </div>
</div>

