<p class="flash-notice" style="color: green"><%= notice %></p>

<div class="article-container">
  <div class="article-header">
    <h1 class="article-title"><%= @article.title %></h1>
    <div class="article-meta">
      投稿日時: <%= @article.created_at.strftime("%Y-%m-%d %H:%M") %>
    </div>
  </div>

  <div class="article-body">
    <%= simple_format @article.content %>
  </div>

  <% if @article.files.attached? %>
    <div class="attachments-section">
      <h3 class="section-title">添付ファイル (<%= @article.files.count %>)</h3>
      <div class="attachments-layout">
        
        <!-- 画像ギャラリー -->
        <% images = @article.files.select(&:image?) %>
        <% if images.any? %>
          <div class="gallery-block">
            <h4>画像ギャラリー</h4>
            <div class="gallery-grid">
              <% images.each do |image| %>
                <div class="gallery-item">
                  <%= link_to url_for(image), target: "_blank", class: "gallery-link" do %>
                    <%= image_tag image, class: "gallery-img" %>
                  <% end %>
                  <div class="gallery-meta">
                    <span class="file-name" title="<%= image.filename %>"><%= image.filename.to_s.truncate(20) %></span>
                    <%= link_to rails_blob_path(image, disposition: "attachment"), class: "btn-download-sm", title: "ダウンロード" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- ドキュメント (PDFその他) -->
        <% docs = @article.files.reject(&:image?) %>
        <% if docs.any? %>
          <div class="docs-block">
            <h4>ドキュメント</h4>
            <div class="docs-list">
              <% docs.each do |doc| %>
                <div class="doc-item">
                  <div class="doc-icon-wrapper">
                    <% if doc.content_type == "application/pdf" %>
                      <div class="doc-icon pdf">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
                        <span>PDF</span>
                      </div>
                    <% else %>
                      <div class="doc-icon generic">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
                        <span><%= doc.filename.extension.to_s.upcase %></span>
                      </div>
                    <% end %>
                  </div>
                  <div class="doc-info">
                    <span class="doc-name" title="<%= doc.filename %>"><%= doc.filename.to_s.truncate(30) %></span>
                    <span class="doc-size"><%= number_to_human_size(doc.byte_size) %></span>
                  </div>
                  <div class="doc-actions">
                    <%= link_to "開く", url_for(doc), target: "_blank", class: "btn btn-sm btn-open" %>
                    <%= link_to "DL", rails_blob_path(doc, disposition: "attachment"), class: "btn btn-sm btn-dl" %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

      </div>
    </div>
  <% end %>

  <div class="article-actions">
    <%= link_to edit_article_path(@article), class: "btn btn-edit" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4z"/></svg>
      編集する
    <% end %>
    <%= link_to articles_path, class: "btn btn-back" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      一覧に戻る
    <% end %>
    <%= button_to @article, method: :delete, class: "btn btn-danger", form: { data: { turbo_confirm: "本当に削除しますか？" }, class: "inline-form" } do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
      削除する
    <% end %>
  </div>
</div>
