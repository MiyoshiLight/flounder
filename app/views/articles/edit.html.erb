<% content_for :title, "Editing article" %>

<div class="form-container">
  <div class="form-header">
    <h1 class="page-title">記事の編集</h1>
    <p class="form-subtitle">内容を更新し、ファイルを個別に追加または削除できます。</p>
  </div>

  <div class="form-card">
    <%= render "form", article: @article %>
  </div>

  <div class="form-footer flex-footer">
    <%= link_to @article, class: "btn-back-link" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>
      詳細を見る
    <% end %>
    <span class="divider">|</span>
    <%= link_to articles_path, class: "btn-back-link" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      一覧に戻る
    <% end %>
  </div>
</div>
