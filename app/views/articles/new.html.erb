<% content_for :title, t("articles.new.title") %>

<div class="form-container">
  <div class="form-header">
    <h1 class="page-title"><%= t("articles.new.title") %></h1>
    <p class="form-subtitle"><%= t("articles.new.description") %></p>
  </div>

  <div class="form-card">
    <%= render "form", article: @article %>
  </div>

  <div class="form-footer">
    <%= link_to articles_path, class: "btn-back-link" do %>
      <%= embedded_svg("arrow-left") %>
      <%= t("articles.new.back") %>
    <% end %>
  </div>
</div>
