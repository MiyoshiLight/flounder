<p class="flash-notice" style="color: green"><%= notice %></p>

<div class="index-header">
  <h1 class="page-title"><%= t("articles.index.title") %></h1>
  <%= link_to new_article_path, class: "btn btn-primary" do %>
    <%= embedded_svg("plus") %>
    <%= t("articles.index.new_post") %>
  <% end %>
</div>

<div class="articles-grid">
  <% @articles.each do |article| %>
    <div class="article-card" id="<%= dom_id article %>">
      
      <div class="card-preview">
        <% if (thumbnail = article.thumbnail_image) %>
          <%= image_tag thumbnail, class: "card-img" %>
        <% elsif article.files_count > 0 %>
          <div class="card-placeholder doc-only">
            <%= embedded_svg("file") %>
            <span><%= t("articles.index.files_count", count: article.files_count) %></span>
          </div>
        <% else %>
          <div class="card-placeholder empty">
            <%= embedded_svg("file-text") %>
            <span><%= t("articles.index.no_attachments") %></span>
          </div>
        <% end %>
      </div>

      <div class="card-content">
        <h2 class="card-title"><%= article.title %></h2>
        <p class="card-text"><%= truncate(article.content, length: 80) %></p>
        
        <div class="card-meta">
          <span class="card-date"><%= article.created_at.strftime("%Y-%m-%d") %></span>
          <% if article.files_count > 0 %>
            <span class="card-badge">
              <%= embedded_svg("clip") %>
              <%= t("articles.index.files", count: article.files_count) %>
            </span>
          <% end %>
        </div>
      </div>

      <div class="card-actions">
        <%= link_to article, class: "btn btn-card-view" do %>
          <%= t("articles.index.view_details") %>
          <%= embedded_svg("arrow-right") %>
        <% end %>
      </div>

    </div>
  <% end %>
</div>
