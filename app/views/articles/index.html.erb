<p class="flash-notice" style="color: green"><%= notice %></p>

<div class="index-header">
  <h1 class="page-title">共有ドキュメント & 記事一覧</h1>
  <%= link_to new_article_path, class: "btn btn-primary" do %>
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    新規記事を投稿
  <% end %>
</div>

<div class="articles-grid">
  <% @articles.each do |article| %>
    <div class="article-card" id="<%= dom_id article %>">
      
      <!-- サムネイルプレビュー領域 -->
      <div class="card-preview">
        <% if article.files.attached? %>
          <% first_image = article.files.select(&:image?).first %>
          <% if first_image %>
            <%= image_tag first_image, class: "card-img" %>
          <% else %>
            <!-- 画像がなく、PDF等のドキュメントがある場合 -->
            <div class="card-placeholder doc-only">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
              <span><%= article.files.count %> 個のファイル</span>
            </div>
          <% end %>
        <% else %>
          <div class="card-placeholder empty">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16c0 1.1.9 2 2 2h12a2 2 0 0 0 2-2V8l-6-6z"/><path d="M14 3v5h5M16 13H8M16 17H8M10 9H8"/></svg>
            <span>添付ファイルなし</span>
          </div>
        <% end %>
      </div>

      <div class="card-content">
        <h2 class="card-title"><%= article.title %></h2>
        <p class="card-text"><%= truncate(article.content, length: 80) %></p>
        
        <div class="card-meta">
          <span class="card-date"><%= article.created_at.strftime("%Y-%m-%d") %></span>
          <% if article.files.attached? %>
            <span class="card-badge">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
              <%= article.files.count %> ファイル
            </span>
          <% end %>
        </div>
      </div>

      <div class="card-actions">
        <%= link_to article, class: "btn btn-card-view" do %>
          詳細を見る
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        <% end %>
      </div>

    </div>
  <% end %>
</div>
