<%= form_with(model: article) do |form| %>
  <% if article.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(article.errors.count, "error") %> prohibited this article from being saved:</h2>

      <ul>
        <% article.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div id="purge-fields-container"></div>

  <div class="form-group">
    <%= form.label :title, t("articles.form.title"), style: "display: block" %>
    <%= form.text_field :title, placeholder: t("articles.form.title_placeholder") %>
  </div>

  <div class="form-group">
    <%= form.label :content, t("articles.form.content"), style: "display: block" %>
    <%= form.textarea :content, rows: 6, placeholder: t("articles.form.content_placeholder") %>
  </div>

  <div class="form-group">
    <%= form.label :files, t("articles.form.files"), style: "display: block" %>
    <div class="file-input-wrapper">
      <%= form.file_field :files, multiple: true, class: "file-input" %>
      <div class="file-input-trigger">
        <%= embedded_svg("upload") %>
        <span><%= t("articles.form.choose_files") %></span>
      </div>
    </div>
    
    <div id="new-files-preview" class="new-files-preview-container" data-template-title="<%= t("articles.form.js.add_files_title", count: "__count__") %>"></div>
  </div>

  <% if article.persisted? && article.files.attached? %>
    <div class="attached-files-section">
      <h4><%= t("articles.form.uploaded_files") %></h4>
      <div class="attached-files-grid">
        <% article.files.each do |file| %>
          <div class="attached-file-item" data-id="<%= file.id %>">
            <div class="file-preview">
              <% if file.image? %>
                <%= image_tag file, class: "preview-img" %>
              <% elsif file.content_type == "application/pdf" %>
                <div class="file-icon pdf">
                  <%= embedded_svg("file") %>
                  <span class="ext-badge">PDF</span>
                </div>
              <% else %>
                <div class="file-icon doc">
                  <%= embedded_svg("file") %>
                  <span class="ext-badge"><%= file.filename.extension.to_s.upcase %></span>
                </div>
              <% end %>
            </div>
            <div class="file-meta">
              <span class="file-name" title="<%= file.filename %>"><%= file.filename.to_s.truncate(15) %></span>
              <span class="file-size"><%= number_to_human_size(file.byte_size) %></span>
            </div>
            
            <button type="button" class="btn-toggle-delete" data-id="<%= file.id %>" 
                    title="<%= t("articles.form.delete_title") %>"
                    data-title-delete="<%= t("articles.form.delete_title") %>"
                    data-title-undo="<%= t("articles.form.undo_delete_title") %>">
              <%= embedded_svg("trash", class: "icon-trash") %>
              <%= embedded_svg("undo", class: "icon-undo") %>
            </button>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="form-actions">
    <%= form.submit t("articles.form.save"), class: "btn btn-primary" %>
  </div>
<% end %>

<template id="new-file-item-template">
  <div class="new-file-item">
    <div class="new-file-icon">
      <%= embedded_svg("file") %>
    </div>
    <div class="new-file-meta">
      <span class="new-file-name"></span>
      <span class="new-file-size"></span>
    </div>
  </div>
</template>

<%= javascript_include_tag "articles_form", "data-turbo-track": "reload" %>

